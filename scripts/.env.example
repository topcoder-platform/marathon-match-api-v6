# Full Marathon Match test runner environment.
# Copy this file to scripts/.env, fill in the values, then load it before running:
# set -a; source scripts/.env; set +a

# Shared API base. Service-specific bases can usually stay empty unless testing split deployments.
TOPCODER_API_BASE="https://api.topcoder-dev.com/v6"
API_BASE="https://api.topcoder-dev.com/v6"
MM_API_BASE="https://api.topcoder-dev.com/v6/marathon-match"
CHALLENGE_API_BASE="https://api.topcoder-dev.com/v6/challenges"
RESOURCE_API_BASE="https://api.topcoder-dev.com/v6/resources"
REVIEW_API_BASE="https://api.topcoder-dev.com/v6/reviews"
SUBMISSION_API_BASE="https://api.topcoder-dev.com/v6/submissions"

# Authentication. Use TOKEN/AUTH_TOKEN directly, or configure Auth0 client credentials.
TOKEN=""

# Fixture and challenge creation.
MM_TEST_FIXTURE_DIR="scripts/fixtures/Blocks"
CHALLENGE_ID=""
CHALLENGE_NAME="Blocks Full Marathon Match Test"
CHALLENGE_TYPE_ID="929bc408-9cf2-4b3e-ba71-adfbf693046c"
CHALLENGE_TRACK_ID="c0f5d461-8219-4c14-878a-c3a3f356466d"
TIMELINE_TEMPLATE_ID="6969125a-a12f-4b89-8de6-e66b0056f36b"
PROJECT_ID="100575"
REGISTRATION_PHASE_ID="a93544bc-c165-4af4-b55e-18f3593b457a"
SUBMISSION_PHASE_ID="6950164f-3c5e-4bdc-abc8-22aaf5a1bd49"
REGISTRATION_DURATION_SECONDS="3600"
SUBMISSION_DURATION_SECONDS="3600"

# Production fixture export. Used by pnpm fixtures:mm:from-prod.
SOURCE_CHALLENGE_ID=""
SOURCE_API_BASE="https://api.topcoder.com/v6"
SOURCE_REVIEW_API_BASE=""
SOURCE_SUBMISSION_TYPE="CONTEST_SUBMISSION"
SOURCE_PER_PAGE="100"
MAX_SOURCE_SUBMISSIONS="0"
MM_FIXTURE_NAME="Blocks"
MM_FIXTURE_ROOT="scripts/fixtures"
MM_FIXTURE_DIR=""
MM_FIXTURE_OVERWRITE="false"
MM_FIXTURE_LATEST_ONLY="false"
MM_FIXTURE_SKIP_DOWNLOADS="false"

# Tester overrides. Leave empty to use the manifest or infer the class name from tester.java.
TESTER_NAME="BlocksTester"
TESTER_VERSION="1.0.0"
TESTER_CLASS_NAME="BlockGameTester"

# Marathon Match config. Leave the first three empty only if /marathon-match/challenge/defaults is configured.
TEST_TIMEOUT_MS="90000"
COMPILE_TIMEOUT_MS="120000"

# Resource API.
SUBMITTER_ROLE_ID="732339e7-8e30-49d7-9198-cccf9451e221"
RESOURCE_SUBMITTER_ROLE_ID="732339e7-8e30-49d7-9198-cccf9451e221"

# Submission upload. Required for local submission files unless MANUAL_SUBMISSION_UPLOAD is true.
SUBMISSION_UPLOAD_BUCKET="topcoder-dev-submissions-dmz"
SUBMISSION_UPLOAD_PREFIX="marathon-match-full-test"
SUBMISSION_UPLOAD_BASE_URL=""
MANUAL_SUBMISSION_UPLOAD="false"
SUBMISSION_TYPE="CONTEST_SUBMISSION"

# Validation and polling.
MIN_ARTIFACTS="1"
WAIT_TIMEOUT_MS="1800000"
POLL_INTERVAL_MS="10000"
SCORE_TOLERANCE="0.000001"
REQUIRE_TEST_SCORES="false"
