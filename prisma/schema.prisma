generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["marathon_match"]
}

enum PhaseConfigType {
  EXAMPLE
  PROVISIONAL
  SYSTEM

  @@schema("marathon_match")
}

enum CompilationStatus {
  PENDING
  SUCCESS
  FAILED

  @@schema("marathon_match")
}

enum ScoreDirection {
  MAXIMIZE
  MINIMIZE

  @@schema("marathon_match")
}

model tester {
  id                String                 @id @default(dbgenerated("nanoid()")) @db.VarChar(14)
  name              String
  version           String
  sourceCode        String                 @db.Text
  jarFile           Bytes?
  className         String
  compilationStatus CompilationStatus      @default(PENDING)
  compilationError  String?                @db.Text
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  createdBy         String?
  updatedBy         String?
  configs           marathonMatchConfig[]

  @@index([id])
  @@index([name])
  @@index([compilationStatus])
  @@unique([name, version])
  @@schema("marathon_match")
}

model marathonMatchConfig {
  id                    String        @id @default(dbgenerated("nanoid()")) @db.VarChar(14)
  challengeId           String        @unique @db.VarChar(36)
  name                  String
  active                Boolean       @default(true)
  relativeScoringEnabled Boolean      @default(true)
  scoreDirection        ScoreDirection @default(MAXIMIZE)
  submissionApiUrl      String
  reviewScorecardId     String
  testerId              String        @db.VarChar(14)
  testTimeout           Int
  compileTimeout        Int
  systemTestTimeout     Int           @default(86400000)
  taskDefinitionName    String
  taskDefinitionVersion String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  createdBy             String?
  updatedBy             String?
  tester                tester        @relation(fields: [testerId], references: [id])
  phaseConfigs          phaseConfig[]

  @@index([testerId])
  @@index([active])
  @@schema("marathon_match")
}

model phaseConfig {
  id                    String              @id @default(dbgenerated("nanoid()")) @db.VarChar(14)
  marathonMatchConfigId String              @db.VarChar(14)
  configType            PhaseConfigType
  startSeed             BigInt
  numberOfTests         Int
  phaseId               String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  marathonMatchConfig   marathonMatchConfig @relation(fields: [marathonMatchConfigId], references: [id], onDelete: Cascade)

  @@index([marathonMatchConfigId])
  @@index([configType])
  @@index([phaseId])
  @@unique([marathonMatchConfigId, configType])
  @@schema("marathon_match")
}

model submissionRunnerLog {
  id                       String          @id @default(dbgenerated("nanoid()")) @db.VarChar(14)
  submissionId             String
  challengeId              String          @db.VarChar(36)
  taskArn                  String          @unique
  taskId                   String
  cluster                  String
  containerName            String
  taskDefinition           String
  phaseConfigType          PhaseConfigType?
  logGroup                 String?
  logStreamPrefix          String?
  logStreamName            String?
  cloudWatchLogsConsoleUrl String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([submissionId])
  @@index([challengeId])
  @@index([createdAt])
  @@schema("marathon_match")
}

model testSubmissionRun {
  id                       String          @id @default(dbgenerated("nanoid()")) @db.VarChar(14)
  challengeId              String          @db.VarChar(36)
  configType               PhaseConfigType
  memberId                 String?
  fileName                 String
  mimeType                 String?
  fileSize                 Int
  fileContent              Bytes
  status                   String          @default("QUEUED")
  score                    Float?
  message                  String?         @db.Text
  metadata                 Json?
  currentReview            Json?
  impactedReviews          Json?
  progress                 Float?
  completedTests           Int?
  totalTests               Int?
  failedTests              Int?
  taskArn                  String?
  taskId                   String?
  cloudWatchLogsConsoleUrl String?
  completedAt              DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  createdBy                String?

  @@index([challengeId])
  @@index([status])
  @@index([createdAt])
  @@schema("marathon_match")
}

model scoringCompletionEmailNotification {
  id               String    @id @default(dbgenerated("nanoid()")) @db.VarChar(14)
  challengeId      String    @db.VarChar(36)
  submissionId     String
  notificationType String    @default("EXAMPLE_PROVISIONAL")
  memberHandle     String?
  recipientEmail   String?
  status           String    @default("PROCESSING")
  errorMessage     String?   @db.Text
  sentAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([challengeId, submissionId, notificationType])
  @@index([challengeId])
  @@index([submissionId])
  @@index([notificationType])
  @@index([status])
  @@schema("marathon_match")
}
